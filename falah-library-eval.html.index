          <div class="fld full">
            <label>نص الرسالة</label>
            <textarea id="email-body" style="min-height:100px">السلام عليكم،

مرفق تقرير تقييم مكتبات أكاديمية الفلاح للعام الدراسي 2026.

يشمل التقرير:
- تقييم جميع مكتبات الفروع الست
- تحليل مجموعات الإمارات
- مقارنة شاملة بين الفروع
- توصيات وخطة تطوير

مع التحية،
مركز مصادر التعلم — أكاديمية الفلاح</textarea>
          </div>
        </div>
        <div class="email-formats">
          <button class="efmt efmt-pdf" onclick="expWord()"><span style="font-size:18px">📄</span> تصدير Word</button>
          <button class="efmt efmt-gmail" onclick="sendGmail()">
            <span style="font-size:18px">📧</span> فتح Gmail وإرسال
          </button>
          <button class="efmt efmt-pdf" onclick="window.print()">
            <span style="font-size:18px">📄</span> طباعة / حفظ PDF ثم إرفاقه
          </button>
          <button class="efmt efmt-json" onclick="expAll()">
            <span style="font-size:18px">📤</span> تصدير JSON للإرفاق
          </button>
          <button class="efmt efmt-csv" onclick="expCSV()">
            <span style="font-size:18px">📊</span> تصدير CSV للإرفاق
          </button>
        </div>
        <div class="email-note">
          💡 <strong>طريقة الإرسال:</strong> اضغط "فتح Gmail" — سيفتح تلقائياً رسالة جديدة في Gmail مع العنوان والنص. ثم أرفق الملفات التي صدّرتها (PDF أو JSON أو CSV) يدوياً قبل الإرسال.
          <br>📱 يعمل مع Gmail وOutlook وأي بريد إلكتروني آخر.
        </div>
      </div>

      <div class="card">
        <div class="cardh"><div class="cnum">📋</div><div><div class="ctitle">إرسال تقرير مدرسة محددة</div><div class="csub">اختر المدرسة وأرسل تقريرها مباشرة</div></div></div>
        <div class="g2">
          <div class="fld">
            <label>اختر المدرسة</label>
            <select id="email-school">
              <option value="">— اختر المدرسة —</option>
            </select>
          </div>
          <div class="fld">
            <label>البريد الإلكتروني للمستلم</label>
            <input type="email" id="email-to2" placeholder="example@gmail.com">
          </div>
        </div>
        <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap">
          <button class="btn bp" onclick="sendSchoolReport()">📧 إرسال تقرير المدرسة عبر Gmail</button>
          <button class="btn bg" onclick="expSchoolWord()">Word تقرير المدرسة</button>
          <button class="btn bg" onclick="expSchoolPDF()">📄 طباعة تقرير المدرسة</button>
          <button class="btn bt" onclick="expSchoolJSON()">📤 تصدير JSON للمدرسة</button>
        </div>
      </div>

      <div class="card">
        <div class="cardh"><div class="cnum">📬</div><div><div class="ctitle">إرسال التقرير الشامل للإدارة العليا</div></div></div>
        <div class="fld">
          <label>بريد الإدارة العليا</label>
          <input type="email" id="email-admin" placeholder="admin@alfalah.ae">
        </div>
        <div class="email-formats" style="margin-top:12px">
          <button class="efmt efmt-gmail" onclick="sendAdminReport()">
            <span>📧</span> إرسال التقرير الشامل للإدارة
          </button>
          <button class="efmt efmt-pdf" onclick="pg('page-rep','التقرير النهائي','nav-rep');setTimeout(()=>window.print(),500)">
            <span>📄</span> طباعة التقرير النهائي
          </button>
        </div>
      </div>
    </div>

</div>
<!-- ══════════ PRESENTATION OVERLAY ══════════ -->
<div class="pov" id="pov">
  <div class="psl" id="psl" style="background:linear-gradient(160deg,#0c447c,#185fa5,#0f6e56)"></div>
  <div class="pnav">
    <button class="btn bo bsm" onclick="pB()">→ السابق</button>
    <span class="pcnt" id="pcnt">1 / 1</span>
    <button class="btn bo bsm" onclick="pN()">← التالي</button>
    <button class="btn br bsm" onclick="closePres()" style="margin-right:24px">✕ إغلاق</button>
  </div>
</div>

<script>
const AF_LOGO_DATA="data:image/png;base64,";

// Page navigation fix for new layout
function pg(id,title,nid){
  document.querySelectorAll(".pg").forEach(p=>p.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  document.getElementById("pgtitle").textContent=title;
  document.querySelectorAll(".navbtn").forEach(n=>n.classList.remove("active"));
  if(nid)document.getElementById(nid)?.classList.add("active");
  if(id==="page-home")uHome();if(id==="page-sch")uSch();
  if(id==="page-cmp")uCmp();if(id==="page-dat")uDat();if(id==="page-rep")uRep();
  if(id==="page-ch")setTimeout(uCh,100);
}
function toggleSB(){}


const SCH=[
  {id:"khb",name:"أكاديمية الفلاح فرع الخبيصي",short:"الخبيصي",city:"العين",day:"الثلاثاء",date:"2026-04-28"},
  {id:"jmi",name:"أكاديمية الفلاح فرع الجيمي",short:"الجيمي",city:"العين",day:"الأربعاء",date:"2026-04-29"},
  {id:"shj",name:"مدرسة الفلاح الخاصة - الدخيلات",short:"الشارقة",city:"الشارقة",day:"الثلاثاء",date:"2026-05-05"},
  {id:"bny",name:"أكاديمية الفلاح فرع بني ياس",short:"بني ياس",city:"أبوظبي",day:"الخميس",date:"2026-05-07"},
  {id:"mzd",name:"أكاديمية الفلاح فرع محمد بن زايد",short:"محمد بن زايد",city:"أبوظبي",day:"الاثنين",date:"2026-05-11"},
  {id:"dan",name:"أكاديمية الفلاح فرع الدانة",short:"الدانة",city:"أبوظبي",day:"الثلاثاء",date:"2026-05-12"},
];
const LSK="falah_lib_v6";
let DB={ev:{}};let CI={};let RS={};let PS=[],PI=0;
function ldb(){try{const s=localStorage.getItem(LSK);if(s)DB=JSON.parse(s);}catch(e){}}
function sdb(){try{localStorage.setItem(LSK,JSON.stringify(DB));}catch(e){alert("خطأ في الحفظ!");}}
function pg(id,title,nid){
  document.querySelectorAll(".pg").forEach(p=>p.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  document.getElementById("pgtitle").textContent=title;
  document.querySelectorAll(".navbtn").forEach(n=>n.classList.remove("active"));
  if(nid)document.getElementById(nid)?.classList.add("active");
  if(id==="page-home")uHome();if(id==="page-sch")uSch();
  if(id==="page-cmp")uCmp();if(id==="page-dat")uDat();if(id==="page-rep")uRep();
  if(id==="page-ch")setTimeout(uCh,100);
}
const RM={"ضعيف جداً":1,"ضعيف":2,"مقبول":3,"جيد":4,"جيد جداً":5,"متميز":6};
const RL={1:"ضعيف جداً",2:"ضعيف",3:"مقبول",4:"جيد",5:"جيد جداً",6:"متميز"};
function avgA(a){const v=a.filter(x=>x>0);return v.length?Math.round(v.reduce((s,x)=>s+x,0)/v.length*10)/10:0;}
function calcSc(d){
  const R=k=>d["r_"+k]||0;
  return{
    "المجموعات":avgA([R("cd"),R("cc"),R("cco")]),
    "مجموعات الإمارات":avgA([R("uae")]),
    "التنظيم الفني":avgA([R("sh"),R("cr")]),
    "البيئة":avgA([R("sp"),R("se"),R("at"),R("in")]),
    "الأنشطة":avgA([R("rch"),R("tu"),R("cu"),R("ri")]),
    "الشراكات":avgA([R("pa"),R("co"),R("ts"),R("ss")]),
    "الكادر والمؤهلات":avgA([R("sb"),R("sc"),R("sst"),R("si"),R("ste"),R("scol"),R("marc"),R("ils")]),
    "التقنية":avgA([R("dg"),R("te"),R("un")]),
  };
}
function tot(sc){const v=Object.values(sc).filter(x=>x>0);return v.length?Math.round(v.reduce((s,x)=>s+x,0)/v.length*10)/10:0;}
function allD(){return SCH.map(s=>{const d=DB.ev[s.id];return{s,d:d||null,sc:d&&d.saved?calcSc(d):null};}).filter(r=>r.sc);}
function uHome(){
  const done=SCH.filter(s=>DB.ev[s.id]?.saved).length;
  document.getElementById("hd").textContent=done;
  document.getElementById("hl").textContent=SCH.reduce((n,s)=>n+(DB.ev[s.id]?.hasEx?2:1),0);
  const avgs=SCH.map(s=>DB.ev[s.id]).filter(e=>e?.saved&&e.overall).map(e=>RM[e.overall]||0);
  if(avgs.length)document.getElementById("ha").textContent=RL[Math.round(avgs.reduce((a,b)=>a+b)/avgs.length)]||"—";
  document.getElementById("hcards").innerHTML=SCH.map(s=>{
    const d=DB.ev[s.id];const ok=!!(d?.saved);
    return`<div class="scard ${ok?"done":""}" onclick="goEv('${s.id}')"><div class="scem">${s.city}</div><div class="scname">${s.name}</div><div class="scdate">📅 ${s.day} ${s.date}</div><div class="scbdg">${ok?'<span class="bdg bg2">✓ مكتمل</span>':'<span class="bdg ba">لم يبدأ</span>'}</div></div>`;
  }).join("");
  const today=new Date().toISOString().split("T")[0];
  document.getElementById("hvtbl").innerHTML=SCH.map((s,i)=>{
    const d=DB.ev[s.id];const ok=!!(d?.saved);const iT=s.date===today;
    const st=ok?'<span class="vb vbd">✓ مكتمل</span>':iT?'<span class="vb vbt">اليوم</span>':'<span class="vb vbp">قادم</span>';
    return`<tr><td>${i+1}</td><td>${s.name}</td><td>${s.city}</td><td>${s.day} ${s.date}</td><td>${st}</td><td><button class="btn bp bxs" onclick="goEv('${s.id}')">تقييم</button></td></tr>`;
  }).join("");
}
function goEv(sid){document.getElementById("esch").value=sid;onSch();pg("page-ev","نموذج التقييم","nav-ev");}
function uSch(){
  const today=new Date().toISOString().split("T")[0];
  document.getElementById("stbl").innerHTML=SCH.map((s,i)=>{
    const d=DB.ev[s.id];const ok=!!(d?.saved);const iT=s.date===today;
    const st=ok?'<span class="vb vbd">✓ مكتمل</span>':iT?'<span class="vb vbt">اليوم</span>':'<span class="vb vbp">قادم</span>';
    return`<tr><td>${i+1}</td><td><strong>${s.day}</strong><br>${s.date}</td><td>${s.name}</td><td>${s.city}</td><td>${st}</td><td><button class="btn bp bxs" onclick="goEv('${s.id}')">تقييم</button></td></tr>`;
  }).join("");
}
function popSel(){
  const sel=document.getElementById("esch");
  sel.innerHTML='<option value="">— اختر المدرسة —</option>'+SCH.map(s=>`<option value="${s.id}">${s.name} — ${s.city}${DB.ev[s.id]?.saved?" ✓":""}</option>`).join("");
}
function qp(fid,pill,gid){
  document.querySelectorAll("#"+gid+" .pill").forEach(p=>p.classList.remove("sel"));
  pill.classList.add("sel");
  const el=document.getElementById(fid);if(el)el.value=pill.textContent.replace(/🔴|🟠|🔵|🟢/g,"").trim();
}
const RCL=["","ra1","ra2","ra3","ra4","ra5","ra6"];
function sR(k,v,btn){
  const c=document.getElementById("rp-"+k);if(!c)return;
  c.querySelectorAll(".rpill").forEach((b,i)=>{RCL.forEach(cl=>{if(cl)b.classList.remove(cl);});if(i<v)b.classList.add(RCL[v]);});
  RS[k]=v;
}
function clrRS(){RS={};document.querySelectorAll(".rp").forEach(rp=>rp.querySelectorAll(".rpill").forEach(b=>RCL.forEach(c=>{if(c)b.classList.remove(c);})));}
function ldRS(d){["uae","cd","cc","cco","sh","cr","sp","se","at","in","rch","tu","cu","ri","pa","co","ts","ss","sb","sc","sst","si","ste","dg","te","un"].forEach(k=>{if(d?.["r_"+k])sR(k,d["r_"+k],null);});}
function togEx(){
  const c=document.getElementById("excnt");const b=document.getElementById("exbtn");const box=document.getElementById("exbox");
  const o=c.classList.toggle("open");box.classList.toggle("open",o);b.textContent=o?"— إخفاء":"+ إضافة";
}
function onSch(){
  const sid=document.getElementById("esch").value;const w=document.getElementById("eform");
  if(!sid){w.style.display="none";return;}
  w.style.display="block";
  const s=SCH.find(x=>x.id===sid);
  if(s){document.getElementById("f-city").value=s.city;document.getElementById("f-sname").value=s.name;}
  ldEv(sid);
}
function gv(id){const el=document.getElementById(id);return el?el.value:"";}
function sv(id,v){const el=document.getElementById(id);if(el&&v!=null)el.value=v;}
function gk(id){const el=document.getElementById(id);return el?el.checked:false;}
function sk(id,v){const el=document.getElementById(id);if(el)el.checked=!!v;}
function ldEv(sid){
  const d=DB.ev[sid]||{};clrRS();
  document.getElementById("eform").querySelectorAll("input:not([type=checkbox]),textarea,select").forEach(el=>{if(!el.readOnly&&el.id!=="esch")el.value="";});
  document.getElementById("eform").querySelectorAll("input[type=checkbox]").forEach(el=>el.checked=false);
  document.querySelectorAll(".pill").forEach(p=>p.classList.remove("sel"));
  document.getElementById("excnt").classList.remove("open");
  document.getElementById("exbox").classList.remove("open");
  document.getElementById("exbtn").textContent="+ إضافة";
  sv("f-lib",d.lib);sv("f-date",d.date);sv("f-stg",d.stg);sv("f-ltyp",d.ltyp);
  sv("f-stu",d.stu);sv("f-stf",d.stf);sv("f-ldesc",d.ldesc);sv("f-uaen",d.uaen);
  sv("f-bt",d.bt);sv("f-bar",d.bar);sv("f-ben",d.ben);sv("f-dig",d.dig);
  sv("f-cls",d.cls);sv("f-cat",d.cat);sv("f-cir",d.cir);sv("f-inv",d.inv);
  sv("f-loans",d.loans);sv("f-vis",d.vis);sv("f-techn",d.techn);
  sv("f-envn",d.envn);sv("f-actn",d.actn);sv("f-rpt",d.rpt);sv("f-ext",d.ext);
  sv("f-parn",d.parn);sv("f-edu",d.edu);sv("f-spc",d.spc);sv("f-exp",d.exp);
  sv("f-crs",d.crs);sv("f-cred",d.cred);sv("f-sdev",d.sdev);sv("f-sstr",d.sstr);sv("f-tr",d.tr);
  sv("f-lsy",d.lsy);sv("f-tecn",d.tecn);sv("f-ovr",d.overall);sv("f-pri",d.priority);
  sv("f-chal",d.chal);sv("f-str",d.str);sv("f-wk",d.wk);sv("f-rec",d.rec);sv("f-plan",d.plan);
  if(d.hasEx){togEx();sv("f-et",d.et);sv("f-es",d.es);sv("f-eb",d.eb);sv("f-er",d.er);sv("f-en",d.en);}
  ["h","c","p","s","g","e","r","a","l","d","n","o"].forEach(k=>sk("uae-"+k,d["uae-"+k]));
  ["tl","dp","ac","uc","dg","co"].forEach(k=>sk("env-"+k,d["env-"+k]));
  ["ar","en","st","ua","bf","cl"].forEach(k=>sk("act-"+k,d["act-"+k]));
  ["y","s","d","m","u","a"].forEach(k=>sk("ft-"+k,d["ft-"+k]));
  ["cls","lib","dig","rd","ch","ref","sys","res","uae","ai","ld","ot"].forEach(k=>sk("cr-"+k,d["cr-"+k]));
  ldRS(d);
}
function getEv(){
  const d={
    lib:gv("f-lib"),date:gv("f-date"),stg:gv("f-stg"),ltyp:gv("f-ltyp"),
    stu:gv("f-stu"),stf:gv("f-stf"),ldesc:gv("f-ldesc"),uaen:gv("f-uaen"),
    bt:gv("f-bt"),bar:gv("f-bar"),ben:gv("f-ben"),dig:gv("f-dig"),
    cls:gv("f-cls"),cat:gv("f-cat"),cir:gv("f-cir"),inv:gv("f-inv"),
    loans:gv("f-loans"),vis:gv("f-vis"),techn:gv("f-techn"),
    envn:gv("f-envn"),actn:gv("f-actn"),rpt:gv("f-rpt"),ext:gv("f-ext"),parn:gv("f-parn"),
    edu:gv("f-edu"),spc:gv("f-spc"),exp:gv("f-exp"),crs:gv("f-crs"),
    cred:gv("f-cred"),sdev:gv("f-sdev"),sstr:gv("f-sstr"),tr:gv("f-tr"),
    lsy:gv("f-lsy"),tecn:gv("f-tecn"),
    overall:gv("f-ovr"),priority:gv("f-pri"),
    chal:gv("f-chal"),str:gv("f-str"),wk:gv("f-wk"),rec:gv("f-rec"),plan:gv("f-plan"),
    hasEx:document.getElementById("excnt").classList.contains("open"),
    et:gv("f-et"),es:gv("f-es"),eb:gv("f-eb"),er:gv("f-er"),en:gv("f-en"),
    saved:true,savedAt:new Date().toISOString()
  };
  ["h","c","p","s","g","e","r","a","l","d","n","o"].forEach(k=>d["uae-"+k]=gk("uae-"+k));
  ["tl","dp","ac","uc","dg","co"].forEach(k=>d["env-"+k]=gk("env-"+k));
  ["ar","en","st","ua","bf","cl"].forEach(k=>d["act-"+k]=gk("act-"+k));
  ["y","s","d","m","u","a"].forEach(k=>d["ft-"+k]=gk("ft-"+k));
  ["cls","lib","dig","rd","ch","ref","sys","res","uae","ai","ld","ot"].forEach(k=>d["cr-"+k]=gk("cr-"+k));
  ["uae","cd","cc","cco","sh","cr","sp","se","at","in","rch","tu","cu","ri","pa","co","ts","ss","sb","sc","sst","si","ste","dg","te","un"].forEach(k=>d["r_"+k]=RS[k]||0);
  return d;
}
function saveEval(){
  const sid=document.getElementById("esch").value;if(!sid)return alert("اختر المدرسة!");
  DB.ev[sid]=getEv();sdb();popSel();uHome();alert("✅ تم حفظ التقييم بنجاح!");
}
function saveAll(){const sid=document.getElementById("esch").value;if(sid&&document.getElementById("eform").style.display!=="none")DB.ev[sid]=getEv();sdb();alert("✅ تم الحفظ");}
function clrEval(){if(!confirm("مسح بيانات النموذج الحالي؟"))return;ldEv(document.getElementById("esch").value||"");}
function uDat(){
  const el=document.getElementById("dtbl");
  el.innerHTML=`<table class="ctbl"><thead><tr><th style="text-align:right">المدرسة</th><th>المدينة</th><th>الأخصائي</th><th>التاريخ</th><th>المؤهل</th><th>الخبرة</th><th>التقييم</th><th>الأولوية</th><th>الحالة</th><th>إجراءات</th></tr></thead><tbody>${SCH.map(s=>{const d=DB.ev[s.id];return`<tr><td style="font-weight:700">${s.name}</td><td>${s.city}</td><td>${d?.lib||"-"}</td><td>${d?.date||"-"}</td><td>${d?.edu||"-"}</td><td>${d?.exp||"-"}</td><td>${d?.overall||"-"}</td><td>${d?.priority||"-"}</td><td>${d?.saved?'<span class="bdg bg2">✓ محفوظ</span>':'<span class="bdg bgr">غير مكتمل</span>'}</td><td style="display:flex;gap:4px"><button class="btn bp bxs" onclick="goEv('${s.id}')">تعديل</button><button class="btn br bxs" onclick="delEv('${s.id}')">حذف</button></td></tr>`;}).join("")}</tbody></table>`;
}
function delEv(sid){if(!confirm("حذف هذا التقييم؟"))return;delete DB.ev[sid];sdb();uDat();uHome();}
function uCmp(){
  const data=allD().sort((a,b)=>tot(b.sc)-tot(a.sc));
  const axes=["المجموعات","مجموعات الإمارات","التنظيم الفني","البيئة","الأنشطة","الشراكات","الكادر والمؤهلات","التقنية"];
  const bc=v=>v>=4.5?"bg2":v>=3?"bb":v>=2?"ba":"br2";
  document.getElementById("cmphead").innerHTML=`<tr><th style="text-align:right">المدرسة</th><th>المدينة</th>${axes.map(a=>`<th>${a}</th>`).join("")}<th>الإجمالي</th><th>التقييم</th><th>الأولوية</th></tr>`;
  if(!data.length){document.getElementById("cmpbody").innerHTML='<tr><td colspan="12" style="text-align:center;padding:30px;color:#5a7fa8">لا توجد بيانات مكتملة — ابدئي بتقييم المدارس أولاً</td></tr>';return;}
  document.getElementById("cmpbody").innerHTML=data.map((r,i)=>{
    const ov=tot(r.sc);
    return`<tr><td>${i+1}. ${r.s.short}${r.d.hasEx?" 📚📚":" 📚"}</td><td>${r.s.city}</td>${axes.map(a=>{const v=r.sc[a]||0;return`<td>${v>0?`<span class="bdg ${bc(v)}">${v}</span>`:"-"}</td>`;}).join("")}<td><span class="bdg ${bc(ov)}" style="font-size:14px">${ov.toFixed(1)}/6</span></td><td>${r.d.overall||"-"}</td><td>${r.d.priority||"-"}</td></tr>`;
  }).join("");
}
const COL=["#185fa5","#0f9d8a","#ba7517","#534ab7","#e24b4a","#0c447c","#1d9e75","#ef9f27"];
function dc(id){if(CI[id]){CI[id].destroy();delete CI[id];}}
function uCh(){
  if(!window.Chart){setTimeout(uCh,500);return;}
  const data=allD().sort((a,b)=>tot(b.sc)-tot(a.sc));
  const axes=["المجموعات","مجموعات الإمارات","التنظيم الفني","البيئة","الأنشطة","الشراكات","الكادر والمؤهلات","التقنية"];
  const lbs=data.map(r=>r.s.short);
  const fo={family:"Cairo",size:12};
  dc("ch-rd");if(data.length){CI["ch-rd"]=new Chart(document.getElementById("ch-rd").getContext("2d"),{type:"radar",data:{labels:axes,datasets:data.map((r,i)=>({label:r.s.short,data:axes.map(a=>r.sc[a]||0),borderColor:COL[i%COL.length],backgroundColor:COL[i%COL.length]+"22",borderWidth:2.5,pointBackgroundColor:COL[i%COL.length]}))},options:{responsive:true,scales:{r:{beginAtZero:true,max:6,ticks:{stepSize:1}}},plugins:{legend:{position:"bottom",labels:{font:fo}}}}});}
  dc("ch-ax");if(data.length){const ap=axes.map(a=>{const vs=data.map(r=>r.sc[a]||0).filter(v=>v>0);return vs.length?Math.round(vs.reduce((s,v)=>s+v,0)/vs.length*10)/10:0;});CI["ch-ax"]=new Chart(document.getElementById("ch-ax").getContext("2d"),{type:"bar",data:{labels:axes,datasets:[{data:ap,backgroundColor:COL,borderRadius:10,borderSkipped:false}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,max:6},x:{ticks:{font:{family:"Cairo",size:10}}}}}});}
  dc("ch-rk");if(data.length){CI["ch-rk"]=new Chart(document.getElementById("ch-rk").getContext("2d"),{type:"bar",data:{labels:lbs,datasets:[{data:data.map(r=>tot(r.sc)),backgroundColor:data.map((_,i)=>COL[i%COL.length]),borderRadius:10,borderSkipped:false}]},options:{indexAxis:"y",responsive:true,plugins:{legend:{display:false}},scales:{x:{beginAtZero:true,max:6},y:{ticks:{font:fo}}}}});}
  dc("ch-ua");if(data.length){CI["ch-ua"]=new Chart(document.getElementById("ch-ua").getContext("2d"),{type:"bar",data:{labels:lbs,datasets:[{label:"مجموعات الإمارات",data:data.map(r=>r.sc["مجموعات الإمارات"]||0),backgroundColor:"#0f9d8a",borderRadius:8,borderSkipped:false},{label:"المجموعات العامة",data:data.map(r=>r.sc["المجموعات"]||0),backgroundColor:"#185fa5",borderRadius:8,borderSkipped:false}]},options:{responsive:true,plugins:{legend:{position:"bottom",labels:{font:fo}}},scales:{y:{beginAtZero:true,max:6},x:{ticks:{font:{family:"Cairo",size:11}}}}}});}
  dc("ch-bk");if(data.length){CI["ch-bk"]=new Chart(document.getElementById("ch-bk").getContext("2d"),{type:"bar",data:{labels:lbs,datasets:[{label:"عربي",data:data.map(r=>parseInt(r.d.bar)||0),backgroundColor:"#185fa5",borderRadius:6},{label:"إنجليزي",data:data.map(r=>parseInt(r.d.ben)||0),backgroundColor:"#0f9d8a",borderRadius:6}]},options:{responsive:true,plugins:{legend:{position:"bottom",labels:{font:fo}}},scales:{x:{stacked:true,ticks:{font:{family:"Cairo",size:11}}},y:{stacked:true,beginAtZero:true}}}});}
  dc("ch-fl");if(data.length){CI["ch-fl"]=new Chart(document.getElementById("ch-fl").getContext("2d"),{type:"bar",data:{labels:axes,datasets:data.map((r,i)=>({label:r.s.short,data:axes.map(a=>r.sc[a]||0),backgroundColor:COL[i%COL.length]+"bb",borderColor:COL[i%COL.length],borderWidth:1.5,borderRadius:6}))},options:{responsive:true,plugins:{legend:{position:"bottom",labels:{font:fo}}},scales:{y:{beginAtZero:true,max:6},x:{ticks:{font:{family:"Cairo",size:11}}}}}});}
}
function scoreLevel(v){
  if(v>=5) return {txt:"متميزة",cls:"bg2",color:"#0f6e56"};
  if(v>=4) return {txt:"جيدة جداً",cls:"bb",color:"#185fa5"};
  if(v>=3) return {txt:"مقبولة وتحتاج تحسين",cls:"ba",color:"#ba7517"};
  return {txt:"تحتاج تدخل عاجل",cls:"br2",color:"#c0392b"};
}
function escHtml(v){return String(v??"").replace(/[&<>\"]/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'\"':"&quot;"}[m]));}
function axisStats(data,axes){
  return axes.map(ax=>{const rows=data.map(r=>({r,v:r.sc[ax]||0})).filter(x=>x.v>0);const avg=rows.length?rows.reduce((s,x)=>s+x.v,0)/rows.length:0;rows.sort((a,b)=>b.v-a.v);return {ax,avg,best:rows[0],weak:rows[rows.length-1]};});
}
function smartRecommendations(r){
  const items=[]; const sc=r.sc;
  Object.entries(sc).forEach(([k,v])=>{if(v>0&&v<3)items.push("إعداد خطة تصحيحية عاجلة لمحور " + k + " في " + r.s.short + "."); else if(v>=3&&v<4)items.push("تحسين محور " + k + " في " + r.s.short + " للوصول إلى مستوى جيد جداً.");});
  if(!r.d["uae-h"]&&!r.d["uae-c"]&&!r.d["uae-s"])items.push("تعزيز مجموعات الإمارات بعناوين في التاريخ والثقافة والقصص المناسبة للمرحلة.");
  if(!r.d.rec && !r.d.plan && items.length===0)items.push("الحفاظ على مستوى الأداء الحالي وتوثيق الممارسات الجيدة لتعميمها.");
  return items.slice(0,5);
}
function buildSchoolReport(r,rank){
  const ov=tot(r.sc);const pct=Math.round((ov/6)*100);const lev=scoreLevel(ov);
  const axes=Object.entries(r.sc).map(([k,v])=>'<tr><td>'+k+'</td><td>'+(v?Number(v).toFixed(1):'—')+'/6</td><td>'+(v?scoreLevel(v).txt:'—')+'</td></tr>').join('');
  const recs=[...(r.d.rec?[r.d.rec]:[]),...smartRecommendations(r)].filter(Boolean).slice(0,6).map(x=>'<li>'+escHtml(x)+'</li>').join('');
  return '<div class="card"><div class="cardh"><div class="cnum">'+(rank||'🏫')+'</div><div><div class="ctitle">'+escHtml(r.s.name)+'</div><div class="csub">'+escHtml(r.s.city)+' — '+escHtml(r.d.date||'بدون تاريخ')+'</div></div></div>'+ 
    '<div class="s4"><div class="sc"><div class="sn">'+ov.toFixed(1)+'/6</div><div class="sl">المتوسط العام</div></div><div class="sc"><div class="sn">'+pct+'%</div><div class="sl">النسبة</div></div><div class="sc"><div class="sn">'+lev.txt+'</div><div class="sl">المستوى</div></div><div class="sc"><div class="sn">'+escHtml(r.d.priority||'—')+'</div><div class="sl">الأولوية</div></div></div>'+ 
    '<div class="g2"><div class="analysis-box"><h4>✅ الإيجابيات المدخلة</h4><p style="font-size:13px;line-height:1.8;white-space:pre-line">'+escHtml(r.d.str||'لم تُدخل إيجابيات نصية بعد.')+'</p></div><div class="analysis-box"><h4>⚠️ الملاحظات والسلبيات</h4><p style="font-size:13px;line-height:1.8;white-space:pre-line">'+escHtml(r.d.wk||r.d.chal||'لم تُدخل ملاحظات سلبية بعد.')+'</p></div></div>'+ 
    '<div style="overflow-x:auto;margin-top:12px"><table class="ctbl"><thead><tr><th>المحور</th><th>الدرجة</th><th>القراءة</th></tr></thead><tbody>'+axes+'</tbody></table></div>'+ 
    '<div class="analysis-box" style="margin-top:12px"><h4>📌 توصيات مقترحة</h4><ul>'+(recs||'<li>لا توجد توصيات حالياً.</li>')+'</ul></div></div>';
}
function uRep(){
  const data=allD().sort((a,b)=>tot(b.sc)-tot(a.sc));
  const el=document.getElementById("repC");
  if(!data.length){el.innerHTML='<div class="al alw">⚠️ لا توجد تقييمات مكتملة. أكملي التقييم أولاً.</div>';return;}
  const axes=["المجموعات","مجموعات الإمارات","التنظيم الفني","البيئة","الأنشطة","الشراكات","الكادر والمؤهلات","التقنية"];
  const stats=axisStats(data,axes);
  const avg=data.reduce((s,r)=>s+tot(r.sc),0)/data.length;
  const level=scoreLevel(avg);
  const best=data[0], weak=data[data.length-1];
  const strengths=stats.filter(x=>x.avg>=4).map(x=>'<li>'+x.ax+': متوسط '+x.avg.toFixed(1)+'/6، وأفضل أداء في '+(x.best?.r.s.short||'—')+'.</li>').join('') || '<li>لم تظهر محاور قوة واضحة بعد؛ يلزم استكمال التقييمات أو رفع المتوسطات.</li>';
  const weaknesses=stats.filter(x=>x.avg>0&&x.avg<4).map(x=>'<li>'+x.ax+': متوسط '+x.avg.toFixed(1)+'/6، ويحتاج دعم أكبر في '+(x.weak?.r.s.short||'—')+'.</li>').join('') || '<li>لا توجد محاور أقل من المستوى الجيد بناءً على البيانات الحالية.</li>';
  const recs=[...new Set(data.flatMap(r=>smartRecommendations(r)))].slice(0,10).map(x=>'<li>'+escHtml(x)+'</li>').join('');
  const cityRows=[...new Set(data.map(r=>r.s.city))].map(city=>{const rows=data.filter(r=>r.s.city===city);const a=rows.reduce((s,r)=>s+tot(r.sc),0)/rows.length;return '<tr><td>'+city+'</td><td>'+rows.length+'</td><td>'+a.toFixed(1)+'/6</td><td>'+scoreLevel(a).txt+'</td></tr>';}).join('');
  el.innerHTML=
  '<div class="card"><div style="text-align:center;margin-bottom:16px"><img src="'+AF_LOGO_DATA+'" alt="شعار أكاديمية الفلاح" style="max-width:190px;width:45%;height:auto;margin:0 auto 10px;display:block"><div style="font-size:24px;font-weight:900;color:var(--navy)">التقرير النهائي الشامل لتقييم المكتبات</div><div style="font-size:13px;color:var(--muted)">أكاديمية الفلاح — مراكز مصادر التعلم | '+new Date().toLocaleDateString("ar-AE")+'</div></div>'+ 
  '<div class="s4"><div class="sc"><div class="sn">'+data.length+'</div><div class="sl">مكتبات مُقيَّمة</div></div><div class="sc"><div class="sn">'+avg.toFixed(1)+'/6</div><div class="sl">المتوسط العام</div></div><div class="sc"><div class="sn">'+best.s.short+'</div><div class="sl">الأعلى تقييماً</div></div><div class="sc"><div class="sn">'+level.txt+'</div><div class="sl">القراءة العامة</div></div></div></div>'+ 
  '<div class="card"><div class="cardh"><div class="cnum">📝</div><div><div class="ctitle">الملخص التنفيذي</div></div></div>'+ 
  '<p style="font-size:14px;line-height:2">يعرض هذا التقرير نتيجة الزيارات الميدانية لمكتبات ومراكز مصادر التعلم في فروع أكاديمية الفلاح. بلغ المتوسط العام <strong>'+avg.toFixed(1)+'/6</strong> بمستوى <strong>'+level.txt+'</strong>. جاء فرع <strong>'+best.s.short+'</strong> في المركز الأعلى، بينما يحتاج فرع <strong>'+weak.s.short+'</strong> إلى متابعة أكبر وفق البيانات المدخلة. يركز التحليل على جودة المجموعات، مجموعات الإمارات، التنظيم الفني، البيئة المكتبية، الأنشطة، الشراكات، الكادر، والتقنية.</p>'+ 
  '<div class="analysis-grid"><div class="analysis-box"><h4>✅ الإيجابيات العامة</h4><ul>'+strengths+'</ul></div><div class="analysis-box"><h4>⚠️ جوانب التحسين</h4><ul>'+weaknesses+'</ul></div><div class="analysis-box"><h4>📌 توصيات تنفيذية</h4><ul>'+(recs||'<li>استكمال إدخال التوصيات النصية لكل فرع.</li>')+'</ul></div></div></div>'+ 
  '<div class="card"><div class="cardh"><div class="cnum">🏆</div><div><div class="ctitle">ترتيب المكتبات — من الأعلى للأدنى</div></div></div>'+ 
  data.map((r,i)=>{const ov=tot(r.sc);const pct=Math.round((ov/6)*100);const lev=scoreLevel(ov);return '<div style="margin-bottom:14px"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px"><div><strong style="font-size:15px">'+(i+1)+'. '+r.s.name+'</strong>'+(r.d.hasEx?' 📚📚':'')+'<br><small style="color:var(--muted)">'+(r.d.lib?'الأخصائي: '+escHtml(r.d.lib)+' | ':'')+(r.d.edu?escHtml(r.d.edu)+' | ':'')+(r.d.exp?escHtml(r.d.exp)+' خبرة':'')+'</small></div><span class="bdg '+lev.cls+'" style="font-size:14px">'+ov.toFixed(1)+'/6 ('+pct+'%)</span></div><div class="pbt"><div class="pbf" style="width:'+pct+'%;background:'+lev.color+'"></div></div><div style="font-size:12px;color:var(--muted);margin-top:4px">'+escHtml(r.d.overall||lev.txt)+' | أولوية: '+escHtml(r.d.priority||'—')+'</div></div>';}).join('')+'</div>'+ 
  '<div class="card"><div class="cardh"><div class="cnum">📊</div><div><div class="ctitle">تحليل المحاور الرئيسية</div></div></div>'+ 
  stats.map(x=>{const pct=Math.round((x.avg/6)*100);const lev=scoreLevel(x.avg);return '<div style="margin-bottom:12px;padding:12px;background:#f5faff;border-radius:10px"><div style="display:flex;justify-content:space-between;margin-bottom:5px"><strong style="color:var(--navy)">'+x.ax+'</strong><span class="bdg '+lev.cls+'">'+x.avg.toFixed(1)+'/6 ('+pct+'%)</span></div><div class="pbt"><div class="pbf" style="width:'+pct+'%;background:'+lev.color+'"></div></div><div style="font-size:12px;color:var(--muted);margin-top:4px">🏆 الأفضل: '+(x.best?.r.s.short||'—')+' | ⚠️ يحتاج دعم: '+(x.weak?.r.s.short||'—')+'</div></div>';}).join('')+'</div>'+ 
  '<div class="card"><div class="cardh"><div class="cnum">🌍</div><div><div class="ctitle">مقارنة المدن</div></div></div><div style="overflow-x:auto"><table class="ctbl"><thead><tr><th>المدينة</th><th>عدد المكتبات</th><th>المتوسط</th><th>القراءة</th></tr></thead><tbody>'+cityRows+'</tbody></table></div></div>'+ 
  data.map((r,i)=>buildSchoolReport(r,i+1)).join('')+ 
  '<div class="card"><div class="cardh"><div class="cnum">✅</div><div><div class="ctitle">الخلاصة الإدارية</div></div></div><p style="font-size:14px;line-height:2">يوصى باعتماد هذا التقرير كمرجع أولي لخطة تطوير مكتبات الأكاديمية، مع متابعة المحاور الأقل من 4/6، وتوثيق ممارسات الفروع الأعلى أداءً، وتحديد جدول زمني واضح لمعالجة الأولويات العاجلة.</p></div>';
}
function wordShell(content,title){return '<!DOCTYPE html><html lang="ar" dir="rtl"><head><meta charset="UTF-8"><title>'+title+'</title><style>body{font-family:Tahoma,Arial,sans-serif;direction:rtl;color:#0c2a4a;line-height:1.8}.card{border:1px solid #b8d4f0;border-radius:12px;padding:16px;margin:14px 0}.cardh{display:flex;gap:10px;border-bottom:1px solid #e8f0fa;margin-bottom:12px;padding-bottom:8px}.cnum{font-weight:bold;color:#0c447c}.ctitle{font-size:18px;font-weight:bold;color:#0c447c}.csub{font-size:12px;color:#5a7fa8}.s4{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}.sc{background:#f5faff;border:1px solid #b8d4f0;border-radius:10px;padding:10px;text-align:center}.sn{font-size:20px;font-weight:bold;color:#0c447c}.sl{font-size:11px;color:#5a7fa8}.ctbl{width:100%;border-collapse:collapse}.ctbl th{background:#0c447c;color:#fff;padding:8px}.ctbl td{border-bottom:1px solid #ddd;padding:7px}.analysis-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.analysis-box{background:#f8fbff;border:1px solid #b8d4f0;border-radius:10px;padding:10px}.pbt{height:8px;background:#dceefb;border-radius:5px;overflow:hidden}.pbf{height:100%}.bdg{display:inline-block;padding:3px 9px;border-radius:12px;background:#e6f1fb;color:#0c447c;font-weight:bold}</style></head><body>'+content+'</body></html>';}
function expWord(){uRep();const c=document.getElementById("repC").innerHTML;dl(new Blob(["\ufeff"+wordShell(c,"التقرير النهائي لتقييم مكتبات أكاديمية الفلاح")],{type:"application/msword;charset=utf-8"}),"التقرير_النهائي_لتقييم_مكتبات_أكاديمية_الفلاح_2026.doc");}
function expSchoolWord(){let sid=document.getElementById("email-school")?.value||document.getElementById("esch")?.value; if(!sid){alert("اختر مدرسة أولاً من صفحة البريد أو نموذج التقييم.");return;} const row=allD().find(r=>r.s.id===sid); if(!row){alert("لا توجد بيانات محفوظة لهذه المدرسة.");return;} const html='<div style="text-align:center"><img src="'+AF_LOGO_DATA+'" style="max-width:180px"><h2>تقرير تقييم مكتبة '+escHtml(row.s.name)+'</h2></div>'+buildSchoolReport(row,1); dl(new Blob(["\ufeff"+wordShell(html,"تقرير "+row.s.short)],{type:"application/msword;charset=utf-8"}),"تقرير_مكتبة_"+row.s.short.replace(/\s+/g,"_")+".doc");}
function dl(blob,fn){const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download=fn;document.body.appendChild(a);a.click();document.body.removeChild(a);}
function expAll(){dl(new Blob([JSON.stringify({v:6,exported:new Date().toISOString(),ev:DB.ev},null,2)],{type:"application/json"}),"تقييم_مكتبات_الفلاح_2026.json");}
function expCSV(){
  const data=allD();if(!data.length){alert("لا توجد بيانات");return;}
  const axes=["المجموعات","مجموعات الإمارات","التنظيم الفني","البيئة","الأنشطة","الشراكات","الكادر والمؤهلات","التقنية"];
  const h=["المدرسة","المدينة","الأخصائي","التاريخ","المؤهل","التخصص","الخبرة","الدورات","الكتب","عربي","إنجليزي","التقييم","الأولوية","مكتبة ثانية",...axes];
  const rows=data.map(r=>[r.s.name,r.s.city,r.d.lib||"",r.d.date||"",r.d.edu||"",r.d.spc||"",r.d.exp||"",r.d.crs||"",r.d.bt||0,r.d.bar||0,r.d.ben||0,r.d.overall||"",r.d.priority||"",r.d.hasEx?"نعم":"لا",...axes.map(a=>(r.sc[a]||0).toFixed(1))]);
  dl(new Blob(["\uFEFF"+[h,...rows].map(r=>r.map(v=>`"${v}"`).join(",")).join("\n")],{type:"text/csv;charset=utf-8"}),"تقييم_مكتبات_الفلاح_2026.csv");
}
function expCurJ(){
  const sid=document.getElementById("esch").value;
  if(!sid){
    alert("⚠️ اختر المدرسة أولاً من نموذج التقييم.");
    return;
  }
  const s=SCH.find(x=>x.id===sid);
  const d=getEv();
  DB.ev[sid]=d;
  sdb();
  popSel();
  uHome();
  dl(
    new Blob([JSON.stringify({
      v:6,
      exported:new Date().toISOString(),
      type:"single_school_evaluation",
      school:s?.name||sid,
      city:s?.city||"",
      ev:{[sid]:d},
      data:d
    },null,2)],{type:"application/json;charset=utf-8"}),
    `تقييم_${(s?.short||sid).replace(/\s+/g,"_")}.json`
  );
}
function impData(){
  const f=document.getElementById("impF").files[0];if(!f)return;
  const reader=new FileReader();
  reader.onload=e=>{
    try{const p=JSON.parse(e.target.result);if(p.ev)Object.assign(DB.ev,p.ev);sdb();popSel();uHome();alert("✅ تم الاستيراد والرفع بنجاح!");}
    catch(err){alert("❌ خطأ في الملف: "+err.message);}
  };
  reader.readAsText(f);document.getElementById("impF").value="";
}
function clrAll(){if(!confirm("حذف جميع البيانات؟ لا يمكن التراجع!"))return;DB.ev={};sdb();uDat();uHome();}
function bldPres(){
  const data=allD().sort((a,b)=>tot(b.sc)-tot(a.sc));
  const logo=`<svg viewBox="0 0 80 92" width="72" height="83" xmlns="http://www.w3.org/2000/svg" style="display:block;margin:0 auto 14px;filter:drop-shadow(0 6px 20px rgba(0,0,0,.4))"><defs><clipPath id="psc"><path d="M40 4 L74 18 L74 50 Q74 72 40 88 Q6 72 6 50 L6 18 Z"/></clipPath></defs><path d="M40 4 L74 18 L74 50 Q74 72 40 88 Q6 72 6 50 L6 18 Z" fill="rgba(255,255,255,.9)"/><rect x="6" y="4" width="34" height="44" fill="#f0a500" clip-path="url(#psc)"/><rect x="40" y="4" width="34" height="44" fill="#1e7fc0" clip-path="url(#psc)"/><rect x="6" y="48" width="34" height="40" fill="#1e7fc0" clip-path="url(#psc)"/><rect x="40" y="48" width="34" height="40" fill="#0f9d8a" clip-path="url(#psc)"/><path d="M58 8 Q22 30 22 78" stroke="white" stroke-width="10" fill="none" stroke-linecap="round" clip-path="url(#psc)"/></svg>`;
  const sl=[];
  sl.push(`<div>${logo}<div style="font-size:38px;font-weight:900;margin-bottom:10px">أكاديمية الفلاح</div><div style="font-size:22px;opacity:.9;margin-bottom:8px">تقرير تقييم المكتبات ومراكز مصادر التعلم</div><div style="font-size:16px;opacity:.7">${new Date().toLocaleDateString("ar-AE")} | 2026</div><div style="margin-top:24px;display:flex;gap:16px;justify-content:center">${["العين","أبوظبي","الشارقة"].map(c=>`<div style="background:rgba(255,255,255,.15);border-radius:10px;padding:10px 18px;font-size:14px">📍 ${c}</div>`).join("")}</div></div>`);
  const rA=data.length?Math.round(data.reduce((s,r)=>s+tot(r.sc),0)/data.length*10)/10:0;
  sl.push(`<div style="max-width:750px;margin:0 auto"><div style="font-size:28px;font-weight:900;margin-bottom:28px">📊 نظرة عامة</div><div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px">${[["6","المدارس"],[data.length+"","مُقيَّمة"],[data.filter(r=>r.d.hasEx).length+"","لديها مكتبتان"],[rA+"/6","المتوسط العام"]].map(([n,l])=>`<div style="background:rgba(255,255,255,.15);border-radius:14px;padding:18px"><div style="font-size:32px;font-weight:900">${n}</div><div style="font-size:13px;opacity:.8;margin-top:4px">${l}</div></div>`).join("")}</div></div>`);
  sl.push(`<div style="max-width:750px;margin:0 auto;width:100%"><div style="font-size:26px;font-weight:900;margin-bottom:22px">🏆 ترتيب المكتبات</div>${data.map((r,i)=>{const ov=tot(r.sc);const pct=Math.round((ov/6)*100);return`<div style="display:flex;align-items:center;gap:14px;margin-bottom:12px;background:rgba(255,255,255,.12);border-radius:12px;padding:12px 16px"><div style="font-size:22px;font-weight:900;width:32px">${i+1}</div><div style="flex:1"><div style="font-weight:700;font-size:15px">${r.s.name}${r.d.hasEx?" 📚📚":""}</div><div style="background:rgba(255,255,255,.2);border-radius:5px;height:8px;margin-top:6px;overflow:hidden"><div style="height:100%;width:${pct}%;background:linear-gradient(90deg,#f0a500,#0f9d8a);border-radius:5px"></div></div></div><div style="font-size:20px;font-weight:900">${pct}%</div></div>`;}).join("")}</div>`);
  sl.push(`<div style="max-width:750px;margin:0 auto;width:100%"><div style="font-size:26px;font-weight:900;margin-bottom:22px">🇦🇪 تقييم مجموعات الإمارات</div>${data.map(r=>{const v=r.sc["مجموعات الإمارات"]||0;const pct=Math.round((v/6)*100);return`<div style="margin-bottom:10px;background:rgba(255,255,255,.12);border-radius:10px;padding:12px 16px;display:flex;align-items:center;gap:14px"><div style="flex:1;font-weight:700">${r.s.short}</div><div style="flex:2;background:rgba(255,255,255,.2);border-radius:5px;height:8px;overflow:hidden"><div style="height:100%;width:${pct}%;background:linear-gradient(90deg,#f0a500,#0f9d8a)"></div></div><div style="font-size:16px;font-weight:900;min-width:40px">${v}/6</div></div>`;}).join("")}</div>`);
  sl.push(`<div style="max-width:700px;margin:0 auto"><div style="font-size:26px;font-weight:900;margin-bottom:22px">🎯 أبرز التوصيات</div>${data.slice(0,5).map(r=>`<div style="background:rgba(255,255,255,.12);border-radius:12px;padding:12px 18px;margin-bottom:12px"><div style="font-weight:700;font-size:14px;margin-bottom:4px">${r.s.short} — أولوية ${r.d.priority||"—"}</div><div style="font-size:13px;opacity:.85">${(r.d.rec||"لم تُدخل توصيات بعد").substring(0,120)}</div></div>`).join("")}<div style="text-align:center;margin-top:24px;font-size:14px;opacity:.65">أكاديمية الفلاح — مركز مصادر التعلم 2026</div></div>`);
  return sl;
}
function startPres(){PS=bldPres();PI=0;rSl();document.getElementById("pov").classList.add("active");}
function rSl(){document.getElementById("psl").innerHTML=PS[PI]||"";document.getElementById("pcnt").textContent=(PI+1)+" / "+PS.length;}
function pN(){if(PI<PS.length-1){PI++;rSl();}}
function pB(){if(PI>0){PI--;rSl();}}
function closePres(){document.getElementById("pov").classList.remove("active");}
document.addEventListener("keydown",e=>{if(!document.getElementById("pov").classList.contains("active"))return;if(e.key==="ArrowLeft"||e.key==="ArrowDown")pN();if(e.key==="ArrowRight"||e.key==="ArrowUp")pB();if(e.key==="Escape")closePres();});
ldb();popSel();uHome();


// Rating tooltip
const RLABELS={1:"❶ غير موجود / ضعيف جداً",2:"❷ ضعيف — يحتاج تدخل عاجل",3:"❸ مقبول — دون المستوى المطلوب",4:"❹ جيد — يلبي الحد الأدنى",5:"❺ جيد جداً — فوق المستوى",6:"❻ متميز / نموذجي"};
document.addEventListener("mouseover",function(e){
  const rpill=e.target.closest(".rpill");
  if(rpill){
    const k=rpill.getAttribute("onclick")?.match(/sR\('([^']+)',([0-9]+)/);
    if(k){
      const v=parseInt(k[2]);
      let tip=document.getElementById("rtip");
      if(!tip){tip=document.createElement("div");tip.id="rtip";tip.style.cssText="position:fixed;background:#0c447c;color:#fff;padding:6px 14px;border-radius:10px;font-size:13px;font-weight:700;font-family:Cairo,sans-serif;z-index:9999;pointer-events:none;box-shadow:0 4px 16px rgba(0,0,0,.25);direction:rtl";document.body.appendChild(tip);}
      tip.textContent=RLABELS[v]||"";
      const r=rpill.getBoundingClientRect();
      tip.style.top=(r.top-42)+"px";
      tip.style.right=(window.innerWidth-r.right+r.width/2-60)+"px";
      tip.style.display="block";
    }
  }
});
document.addEventListener("mouseout",function(e){
  if(e.target.closest(".rpill")){const t=document.getElementById("rtip");if(t)t.style.display="none";}
});


// ══ EMAIL FUNCTIONS ══
function sendGmail(){
  const to=document.getElementById('email-to').value||'';
  const subj=encodeURIComponent(document.getElementById('email-subject').value||'تقرير تقييم مكتبات أكاديمية الفلاح 2026');
  const body=encodeURIComponent(document.getElementById('email-body').value||'');
  const url=`https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(to)}&su=${subj}&body=${body}`;
  window.open(url,'_blank');
}
function sendAdminReport(){
  const to=document.getElementById('email-admin').value||'';
  const data=allD();
  const axes=["المجموعات","مجموعات الإمارات","التنظيم الفني","البيئة","الأنشطة","الشراكات","الكادر والمؤهلات","التقنية"];
  let body='تقرير تقييم مكتبات أكاديمية الفلاح 2026\n\n';
  body+='الملخص التنفيذي:\n';
  body+=`عدد المكتبات المُقيَّمة: ${data.length}\n`;
  if(data.length){
    const sorted=[...data].sort((a,b)=>tot(b.sc)-tot(a.sc));
    body+='\nترتيب المكتبات:\n';
    sorted.forEach((r,i)=>{const pct=Math.round((tot(r.sc)/6)*100);body+=`${i+1}. ${r.s.name}: ${pct}%\n`;});
    body+='\nملاحظات مجموعات الإمارات:\n';
    sorted.forEach(r=>{const v=r.sc["مجموعات الإمارات"]||0;body+=`${r.s.short}: ${v}/6\n`;});
    body+='\nالتوصيات الرئيسية:\n';
    sorted.forEach(r=>{if(r.d.rec)body+=`• ${r.s.short}: ${r.d.rec.substring(0,100)}\n`;});
  }
  const url=`https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(to)}&su=${encodeURIComponent('التقرير الشامل — تقييم مكتبات أكاديمية الفلاح 2026')}&body=${encodeURIComponent(body)}`;
  window.open(url,'_blank');
}
function sendSchoolReport(){
  const sid=document.getElementById('email-school').value;
  const to=document.getElementById('email-to2').value||'';
  if(!sid){alert('اختر المدرسة');return;}
  const s=SCH.find(x=>x.id===sid);
  const d=DB.ev[sid];
  if(!d||!d.saved){alert('لا توجد بيانات محفوظة لهذه المدرسة');return;}
  const sc=calcSc(d);const ov=tot(sc);const pct=Math.round((ov/6)*100);
  let body=`تقرير تقييم مكتبة ${s.name}\n`;
  body+=`المدينة: ${s.city}\n`;
  body+=`تاريخ الزيارة: ${d.date||'—'}\n`;
  body+=`الأخصائي: ${d.lib||'—'}\n\n`;
  body+=`التقييم الإجمالي: ${ov.toFixed(1)}/6 (${pct}%)\n`;
  body+=`التقييم العام: ${d.overall||'—'}\n`;
  body+=`أولوية التدخل: ${d.priority||'—'}\n\n`;
  body+=`مجموعات الإمارات: ${sc["مجموعات الإمارات"]||0}/6\n\n`;
  if(d.rec)body+=`التوصيات:\n${d.rec}\n\n`;
  if(d.plan)body+=`خطة العمل:\n${d.plan}\n`;
  const url=`https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(to)}&su=${encodeURIComponent('تقرير تقييم مكتبة '+s.name+' 2026')}&body=${encodeURIComponent(body)}`;
  window.open(url,'_blank');
}
function expSchoolJSON(){
  const sid=document.getElementById('email-school').value;
  if(!sid){alert('اختر المدرسة');return;}
  const s=SCH.find(x=>x.id===sid);
  const d=DB.ev[sid];
  if(!d){alert('لا توجد بيانات');return;}
  dl(new Blob([JSON.stringify({school:s.name,city:s.city,data:d},null,2)],{type:'application/json'}),`تقرير_${s.short}.json`);
}
function expSchoolPDF(){pg('page-rep','التقرير النهائي','nav-rep');setTimeout(()=>window.print(),600);}
function popEmailSchool(){
  const sel=document.getElementById('email-school');
  if(!sel)return;
  sel.innerHTML='<option value="">— اختر المدرسة —</option>'+SCH.map(s=>`<option value="${s.id}">${s.name}</option>`).join('');
}

// Init email school select
document.addEventListener("DOMContentLoaded",()=>{popEmailSchool();});

// ══ EMAIL / SEND FUNCTIONS ══
function buildGmailUrl(to,sub,body){
  return "https://mail.google.com/mail/?view=cm&fs=1"
    +(to?"&to="+encodeURIComponent(to):"")
    +"&su="+encodeURIComponent(sub||"تقرير مكتبات الفلاح 2026")
    +"&body="+encodeURIComponent(body||"");
}
function buildOutlookUrl(to,sub,body){
  return "https://outlook.live.com/mail/0/deeplink/compose"
    +"?to="+encodeURIComponent(to||"")
    +"&subject="+encodeURIComponent(sub||"")
    +"&body="+encodeURIComponent(body||"");
}
function doGmail(){window.open(buildGmailUrl(document.getElementById("em-to").value,document.getElementById("em-sub").value,document.getElementById("em-body").value),"_blank");}
function doOutlook(){window.open(buildOutlookUrl(document.getElementById("em-to").value,document.getElementById("em-sub").value,document.getElementById("em-body").value),"_blank");}
function doMailto(){
  const to=document.getElementById("em-to").value;
  const sub=encodeURIComponent(document.getElementById("em-sub").value);
  const body=encodeURIComponent(document.getElementById("em-body").value);
  window.location.href="mailto:"+to+"?subject="+sub+"&body="+body;
}
function sendSchool(){
  const sid=document.getElementById("em-school").value;
  const to=document.getElementById("em-to2").value||"";
  if(!sid){alert("اختر المدرسة أولاً");return;}
  const s=SCH.find(x=>x.id===sid);
  const d=DB.ev[sid];
  if(!d||!d.saved){alert("لا توجد بيانات محفوظة لهذه المدرسة — أكملي التقييم أولاً");return;}
  const sc2=calcSc(d);const ov=tot(sc2);const pct=Math.round((ov/6)*100);
  let body="السلام عليكم،\n\n";
  body+="تقرير تقييم مكتبة "+s.name+"\n";
  body+="المدينة: "+s.city+" | تاريخ الزيارة: "+(d.date||"—")+"\n";
  body+="الأخصائي: "+(d.lib||"—")+"\n\n";
  body+="═══ نتائج التقييم ═══\n";
  body+="التقييم الإجمالي: "+ov.toFixed(1)+"/6 ("+pct+"%)\n";
  body+="التقييم العام: "+(d.overall||"—")+" | أولوية التدخل: "+(d.priority||"—")+"\n\n";
  body+="مجموعات الإمارات: "+(sc2["مجموعات الإمارات"]||0)+"/6\n";
  body+="التنظيم الفني: "+(sc2["التنظيم الفني"]||0)+"/6\n";
  body+="البيئة المكتبية: "+(sc2["البيئة"]||0)+"/6\n\n";
  if(d.str)body+="نقاط القوة:\n"+d.str+"\n\n";
  if(d.wk)body+="نقاط الضعف:\n"+d.wk+"\n\n";
  if(d.rec)body+="التوصيات:\n"+d.rec+"\n\n";
  body+="مع التحية،\nمركز مصادر التعلم — أكاديمية الفلاح";
  window.open(buildGmailUrl(to,"تقرير تقييم مكتبة "+s.name+" 2026",body),"_blank");
}
function sendAdmin(){
  const to=document.getElementById("em-admin").value||"";
  const cc=document.getElementById("em-cc").value||"";
  const data=allD().sort((a,b)=>tot(b.sc)-tot(a.sc));
  let body="السلام عليكم ورحمة الله،\n\n";
  body+="التقرير الشامل لتقييم مكتبات أكاديمية الفلاح 2026\n";
  body+="════════════════════════════\n\n";
  body+="عدد المكتبات المُقيَّمة: "+data.length+" من أصل 6\n\n";
  if(data.length){
    body+="ترتيب المكتبات (من الأعلى للأدنى):\n";
    data.forEach((r,i)=>{
      const pct=Math.round((tot(r.sc)/6)*100);
      body+=(i+1)+". "+r.s.name+": "+pct+"% | مجموعات الإمارات: "+(r.sc["مجموعات الإمارات"]||0)+"/6\n";
    });
    body+="\nالتوصيات الرئيسية:\n";
    data.forEach(r=>{if(r.d.rec)body+="• "+r.s.short+": "+r.d.rec.substring(0,120)+"...\n";});
  }
  body+="\nمع التحية،\nمركز مصادر التعلم — أكاديمية الفلاح";
  let url=buildGmailUrl(to,"التقرير الشامل — تقييم مكتبات أكاديمية الفلاح 2026",body);
  if(cc)url+="&cc="+encodeURIComponent(cc);
  window.open(url,"_blank");
}
function expSchJ(){
  const sid=document.getElementById("em-school").value;
  if(!sid){alert("اختر المدرسة");return;}
  const s=SCH.find(x=>x.id===sid);
  dl(new Blob([JSON.stringify({school:s.name,city:s.city,data:DB.ev[sid]||{}},null,2)],{type:"application/json"}),"تقرير_"+s.short+".json");
}
function popEmSch(){
  const sel=document.getElementById("em-school");
  if(!sel)return;
  sel.innerHTML="<option value=''>— اختر المدرسة —</option>"+SCH.map(s=>"<option value='"+s.id+"'>"+s.name+"</option>").join("");
}

// Init
document.addEventListener("DOMContentLoaded",()=>{popEmSch();});
</script>
