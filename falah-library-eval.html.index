              <label>نوع المكتبة</label>
              <select id="f-ltyp"><option>مكتبة مدرسية رئيسية</option><option>مركز مصادر تعلم متكامل</option><option>مكتبة الصفوف الصغيرة KG-4</option><option>مكتبة الصفوف الكبيرة 5-12</option></select>
            </div>
            <div class="fld">
              <label>عدد الطلاب</label>
              <div class="qp" id="qstu"><div class="pill" onclick="qp('f-stu',this,'qstu')">أقل من 300</div><div class="pill" onclick="qp('f-stu',this,'qstu')">300-600</div><div class="pill" onclick="qp('f-stu',this,'qstu')">600-900</div><div class="pill" onclick="qp('f-stu',this,'qstu')">أكثر من 900</div></div>
              <input id="f-stu" placeholder="أو العدد الدقيق...">
            </div>
            <div class="fld">
              <label>عدد العاملين</label>
