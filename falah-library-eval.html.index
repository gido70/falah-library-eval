            <div class="fld">
              <label>المرحلة التي تخدمها المكتبة</label>
              <div class="qp" id="qstg">
                <div class="pill" onclick="qp('f-stg',this,'qstg')">KG رياض أطفال</div>
                <div class="pill" onclick="qp('f-stg',this,'qstg')">حلقة أولى 1-4</div>
                <div class="pill" onclick="qp('f-stg',this,'qstg')">حلقة ثانية 5-8</div>
                <div class="pill" onclick="qp('f-stg',this,'qstg')">حلقة ثالثة 9-12</div>
                <div class="pill" onclick="qp('f-stg',this,'qstg')">متعددة المراحل</div>
              </div>
              <input id="f-stg" placeholder="أو اكتب...">
            </div>
