              <label class="chk" style="background:rgba(255,255,255,.7)"><input type="checkbox" id="uae-n"> 🌊 الطبيعة البحرية</label>
              <label class="chk" style="background:rgba(255,255,255,.7)"><input type="checkbox" id="uae-o"> ➕ أخرى إماراتية</label>
            </div>
            
