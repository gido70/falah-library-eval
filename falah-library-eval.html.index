                  <div class="qp" id="qeb"><div class="pill" onclick="qp('f-eb',this,'qeb')">أقل من 500</div><div class="pill" onclick="qp('f-eb',this,'qeb')">500-1500</div><div class="pill" onclick="qp('f-eb',this,'qeb')">1500-3000</div><div class="pill" onclick="qp('f-eb',this,'qeb')">أكثر من 3000</div></div>
                  <input id="f-eb" placeholder="العدد التقريبي...">
