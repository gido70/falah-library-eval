            <div class="rgrp"><div class="rlbl">تنوع المجموعات</div><div class="rp" id="rp-cd"><button type="button" class="rpill" onclick="sR('cd',1,this)">1</button><button type="button" class="rpill" onclick="sR('cd',2,this)">2</button><button type="button" class="rpill" onclick="sR('cd',3,this)">3</button><button type="button" class="rpill" onclick="sR('cd',4,this)">4</button><button type="button" class="rpill" onclick="sR('cd',5,this)">5</button><button type="button" class="rpill" onclick="sR('cd',6,this)">6</button></div></div>
            <div class="rgrp"><div class="rlbl">حداثة المجموعات</div><div class="rp" id="rp-cc"><button type="button" class="rpill" onclick="sR('cc',1,this)">1</button><button type="button" class="rpill" onclick="sR('cc',2,this)">2</button><button type="button" class="rpill" onclick="sR('cc',3,this)">3</button><button type="button" class="rpill" onclick="sR('cc',4,this)">4</button><button type="button" class="rpill" onclick="sR('cc',5,this)">5</button><button type="button" class="rpill" onclick="sR('cc',6,this)">6</button></div></div>
            <div class="rgrp"><div class="rlbl">توافق المحتوى مع المنهاج</div><div class="rp" id="rp-cco"><button type="button" class="rpill" onclick="sR('cco',1,this)">1</button><button type="button" class="rpill" onclick="sR('cco',2,this)">2</button><button type="button" class="rpill" onclick="sR('cco',3,this)">3</button><button type="button" class="rpill" onclick="sR('cco',4,this)">4</button><button type="button" class="rpill" onclick="sR('cco',5,this)">5</button><button type="button" class="rpill" onclick="sR('cco',6,this)">6</button></div></div>
