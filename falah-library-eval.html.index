<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>نظام تقييم مكتبات أكاديمية الفلاح 2026</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
@import url("https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap");
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --navy:#0c447c;--blue:#185fa5;--teal:#0f9d8a;--gold:#ba7517;--amber:#f0a500;
  --bg:#e8f0fa;--text:#0c2a4a;--muted:#5a7fa8;--border:#b8d4f0;
  --green:#0f6e56;--red:#c0392b;
  --grad:linear-gradient(160deg,#0c447c,#185fa5,#0f6e56);
}
body{font-family:"Cairo",sans-serif;background:var(--bg);color:var(--text);direction:rtl;min-height:100vh;}

/* ══════ TOP HEADER WITH LOGO ══════ */
.site-header{
  background:var(--grad);
  padding:20px 24px 0;
  text-align:center;
  position:relative;
  overflow:hidden;
  box-shadow:0 4px 20px rgba(12,68,124,.3);
}
.site-header::before{content:"";position:absolute;top:-40px;left:-40px;width:200px;height:200px;background:rgba(255,255,255,.06);border-radius:50%;}
.site-header::after{content:"";position:absolute;bottom:-40px;right:-30px;width:180px;height:180px;background:rgba(255,255,255,.05);border-radius:50%;}
.header-logo{position:relative;z-index:2;margin-bottom:10px;}
.header-logo svg{width:80px;height:92px;display:block;margin:0 auto 10px;filter:drop-shadow(0 6px 20px rgba(0,0,0,.4));}
.header-logo .acname{font-size:22px;font-weight:900;color:#fff;letter-spacing:.4px;}
.header-logo .acsub{font-size:13px;color:rgba(255,255,255,.8);margin-top:3px;}

/* ══════ TOP NAV ══════ */
.topnav{
  display:flex;align-items:center;justify-content:center;flex-wrap:wrap;
  gap:2px;padding:12px 20px 0;position:relative;z-index:2;
}
.navbtn{
  display:flex;align-items:center;gap:7px;padding:10px 16px;
  cursor:pointer;transition:all .2s;color:rgba(255,255,255,.8);
  font-size:15px;font-weight:700;font-family:"Cairo",sans-serif;
  border:none;background:transparent;
  border-bottom:3px solid transparent;border-radius:8px 8px 0 0;
}
.navbtn:hover{background:rgba(255,255,255,.12);color:#fff;}
.navbtn.active{background:rgba(255,255,255,.18);color:#ffe07a;border-bottom-color:var(--amber);}
.navbtn .ico{font-size:18px;}
.nav-sep{width:1px;height:32px;background:rgba(255,255,255,.15);margin:0 2px;}

/* ══════ ACTION BAR (below nav) ══════ */
.action-strip{
  background:rgba(255,255,255,.1);border-top:1px solid rgba(255,255,255,.15);
  display:flex;justify-content:center;align-items:center;gap:8px;
  padding:8px 20px;flex-wrap:wrap;
}
.abtn{
  border:1.5px solid rgba(255,255,255,.35);border-radius:20px;
  padding:6px 16px;font-family:"Cairo",sans-serif;font-size:13px;font-weight:700;
  cursor:pointer;color:#fff;background:rgba(255,255,255,.12);
  display:flex;align-items:center;gap:6px;transition:all .2s;
}
.abtn:hover{background:rgba(255,255,255,.25);border-color:rgba(255,255,255,.6);}
.abtn-gold{background:rgba(240,165,0,.3);border-color:var(--amber);}
.abtn-teal{background:rgba(15,157,138,.3);border-color:var(--teal);}

/* ══════ PAGE TITLE BAR ══════ */
.pagebar{
  background:#fff;border-bottom:2px solid var(--border);
  padding:14px 0;text-align:center;
  box-shadow:0 3px 12px rgba(12,68,124,.08);
}
.pagebar-inner{max-width:960px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:center;}
.pagetitle{font-size:20px;font-weight:900;color:var(--navy);}

/* ══════ MAIN CONTENT ══════ */
.content{max-width:960px;width:100%;margin:0 auto;padding:22px 24px;}

/* ══════ HERO ══════ */
.hero{background:var(--grad);border-radius:20px;padding:24px 30px;margin-bottom:22px;color:#fff;text-align:center;position:relative;overflow:hidden;}
.hero::before{content:"";position:absolute;top:-50px;left:-50px;width:220px;height:220px;background:rgba(255,255,255,.06);border-radius:50%;}
.hi{position:relative;z-index:1;}
.hero h2{font-size:22px;font-weight:900;}.hero p{font-size:14px;opacity:.85;margin-top:6px;}

/* ══════ CARDS ══════ */
.card{background:#fff;border-radius:18px;border:1px solid var(--border);box-shadow:0 4px 18px rgba(12,68,124,.07);padding:22px;margin-bottom:18px;}
.cardh{display:flex;align-items:center;gap:14px;margin-bottom:18px;padding-bottom:14px;border-bottom:2px solid var(--bg);}
.cnum{width:44px;height:44px;border-radius:14px;background:var(--grad);color:#fff;display:flex;align-items:center;justify-content:center;font-size:19px;font-weight:900;flex-shrink:0;}
.ctitle{font-size:19px;font-weight:900;color:var(--navy);}.csub{font-size:13px;color:var(--muted);margin-top:3px;}

/* ══════ GRIDS ══════ */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
.full{grid-column:1/-1;}

/* ══════ FORM FIELDS ══════ */
.fld{display:flex;flex-direction:column;gap:5px;}
.fld label{font-size:14px;font-weight:700;color:var(--navy);}
.fld input,.fld select,.fld textarea{border:2px solid var(--border);border-radius:11px;padding:10px 13px;font-family:"Cairo",sans-serif;font-size:14px;color:var(--text);background:#f5faff;outline:none;transition:border .2s;}
.fld input:focus,.fld select:focus,.fld textarea:focus{border-color:var(--blue);background:#fff;box-shadow:0 0 0 3px rgba(24,95,165,.1);}
.fld textarea{min-height:75px;resize:vertical;}
.fld input[readonly]{background:#edf3fb;cursor:default;color:var(--muted);}

/* ══════ QUICK PILLS ══════ */
.qp{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:7px;}
.pill{padding:6px 13px;border-radius:20px;border:1.5px solid var(--border);background:#f5faff;font-size:13px;font-weight:700;color:var(--navy);cursor:pointer;transition:all .2s;user-select:none;}
.pill:hover{border-color:var(--blue);background:#e6f1fb;color:var(--blue);}
.pill.sel{background:var(--navy);color:#fff;border-color:var(--navy);}

/* ══════ RATING PILLS ══════ */
.rgrp{margin:10px 0;}
.rlbl{font-size:14px;font-weight:700;color:var(--navy);margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;}
.rlbl small{font-size:11px;color:var(--muted);font-weight:400;}
.rp{display:flex;gap:5px;}
.rpill{flex:1;min-width:44px;padding:9px 3px;border-radius:10px;border:2px solid var(--border);background:#f5faff;font-family:"Cairo",sans-serif;font-size:12px;font-weight:800;color:var(--muted);cursor:pointer;transition:all .18s;text-align:center;line-height:1.3;}
.rpill:hover{transform:translateY(-2px);border-color:var(--blue);}
.ra1{background:#fdf0f0;border-color:#e24b4a;color:#c0392b;}
.ra2{background:#fef6e8;border-color:#e8920a;color:#b7620a;}
.ra3{background:#fefae8;border-color:#c9a800;color:#8a7000;}
.ra4{background:#e6f1fb;border-color:var(--blue);color:var(--navy);}
.ra5{background:#e1f5ee;border-color:var(--green);color:#085041;}
.ra6{background:#e0f0fe;border-color:#0277bd;color:#014f82;}

/* ══════ CHECKBOXES ══════ */
.cg3{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:8px 0;}
.cg4{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin:8px 0;}
.chk{display:flex;align-items:center;gap:8px;background:#f5faff;border:1.5px solid var(--border);padding:9px 12px;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;}
.chk:hover{border-color:var(--blue);background:#e6f1fb;}
.chk input{accent-color:var(--gold);transform:scale(1.2);flex-shrink:0;}

/* ══════ SECTION DIVIDER ══════ */
.sdiv{display:flex;align-items:center;gap:10px;margin:18px 0 13px;}
.sdivl{flex:1;height:2px;background:linear-gradient(90deg,var(--border),transparent);}
.sdivr{flex:1;height:2px;background:linear-gradient(270deg,var(--border),transparent);}
.sdivt{font-size:14px;font-weight:900;color:var(--navy);white-space:nowrap;padding:5px 14px;background:var(--bg);border-radius:20px;border:1px solid var(--border);}

/* ══════ UAE BOX ══════ */
.ubox{background:linear-gradient(135deg,#e8f4fd,#e6f7f0);border:2px solid var(--teal);border-radius:16px;padding:18px;margin:14px 0;}
.utitle{font-size:16px;font-weight:900;color:#085041;margin-bottom:5px;}
.udesc{font-size:13px;color:#0f5a3d;margin-bottom:14px;line-height:1.6;}

/* ══════ EXTRA LIBRARY ══════ */
.exbox{background:#f0faff;border:2px dashed var(--border);border-radius:14px;margin-top:14px;overflow:hidden;}
.exbox.open{border-color:var(--teal);border-style:solid;background:#e6f7f2;}
.extog{display:flex;align-items:center;justify-content:space-between;cursor:pointer;font-size:15px;font-weight:700;color:var(--navy);padding:14px 16px;}
.excnt{display:none;padding:0 16px 16px;}
.excnt.open{display:block;}

/* ══════ CREDENTIALS ══════ */
.credbox{background:linear-gradient(135deg,#fef9ec,#fff8e6);border:2px solid var(--gold);border-radius:14px;padding:16px;margin:12px 0;}
.credtitle{font-size:15px;font-weight:900;color:var(--gold);margin-bottom:12px;}

/* ══════ BUTTONS ══════ */
.btn{border:none;border-radius:11px;padding:11px 20px;font-family:"Cairo",sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:7px;}
.btn:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(0,0,0,.15);}
.bp{background:var(--grad);color:#fff;}.bg{background:linear-gradient(135deg,var(--gold),var(--amber));color:#fff;}
.bt{background:linear-gradient(135deg,var(--green),var(--teal));color:#fff;}
.br{background:linear-gradient(135deg,#a32d2d,var(--red));color:#fff;}
.bo{background:#fff;border:2px solid var(--border);color:var(--navy);}
.bo:hover{border-color:var(--blue);background:#e6f1fb;}
.bsm{padding:8px 16px;font-size:13px;}.bxs{padding:5px 11px;font-size:12px;}

/* ══════ STATS ══════ */
.s4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:22px;}
.sc{background:#fff;border-radius:16px;padding:18px;text-align:center;border:1px solid var(--border);box-shadow:0 3px 12px rgba(12,68,124,.06);}
.sn{font-size:30px;font-weight:900;color:var(--navy);line-height:1;}
.sl{font-size:12px;color:var(--muted);margin-top:5px;font-weight:700;}

/* ══════ SCHOOL CARDS ══════ */
.scards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px;}
.scard{background:#fff;border:2px solid var(--border);border-radius:16px;padding:16px;cursor:pointer;transition:all .22s;text-align:center;}
.scard:hover{border-color:var(--blue);background:#e8f4fd;transform:translateY(-3px);box-shadow:0 8px 20px rgba(12,68,124,.1);}
.scard.done{border-color:var(--teal);background:#e6f7f2;}
.scem{font-size:11px;font-weight:900;color:var(--muted);letter-spacing:1px;margin-bottom:4px;}
.scname{font-size:14px;font-weight:900;color:var(--navy);line-height:1.3;}
.scdate{font-size:12px;color:var(--gold);margin-top:6px;font-weight:700;}
.scbdg{margin-top:8px;}

/* ══════ VISIT TABLE ══════ */
.vtbl{width:100%;border-collapse:collapse;}
.vtbl th{background:var(--navy);color:#fff;padding:12px 13px;font-size:14px;font-weight:700;text-align:center;}
.vtbl th:first-child{text-align:right;}
.vtbl td{padding:11px 13px;border-bottom:1px solid var(--border);font-size:14px;text-align:center;}
.vtbl tr:hover td{background:#f0f8ff;}.vtbl tr:nth-child(even) td{background:#f8fbff;}
.vb{display:inline-block;padding:4px 13px;border-radius:20px;font-size:13px;font-weight:700;}
.vbd{background:#e1f5ee;color:#085041;}.vbp{background:#faeeda;color:#633806;}
.vbt{background:#e6f1fb;color:#0c447c;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}

/* ══════ BADGE ══════ */
.bdg{display:inline-block;padding:3px 11px;border-radius:16px;font-size:13px;font-weight:700;}
.bg2{background:#e1f5ee;color:#085041;}.bb{background:#e6f1fb;color:#0c447c;}
.ba{background:#faeeda;color:#633806;}.br2{background:#fcebeb;color:#791f1f;}.bgr{background:#f0f0f0;color:#555;}

/* ══════ ALERT ══════ */
.al{padding:12px 16px;border-radius:12px;font-size:14px;font-weight:600;margin-bottom:14px;display:flex;align-items:flex-start;gap:10px;}
.ali{background:#e6f1fb;border:1px solid #b5d4f4;color:#0c447c;}
.alw{background:#faeeda;border:1px solid #fac775;color:#633806;}
.als{background:#e1f5ee;border:1px solid #5dcaa5;color:#085041;}

/* ══════ PBAR ══════ */
.pbt{height:10px;background:#dceefb;border-radius:5px;overflow:hidden;}
.pbf{height:100%;border-radius:5px;transition:width .6s ease;}

/* ══════ PAGES ══════ */
.pg{display:none;}.pg.active{display:block;}

/* ══════ COMPARE TABLE ══════ */
.ctbl{width:100%;border-collapse:collapse;font-size:13px;}
.ctbl th{background:var(--navy);color:#fff;padding:10px;text-align:center;font-size:12px;}
.ctbl th:first-child{text-align:right;}
.ctbl td{padding:9px 10px;border-bottom:1px solid var(--border);text-align:center;}
.ctbl td:first-child{text-align:right;font-weight:700;background:#f8fbff;}
.ctbl tr:hover td{background:#f0f8ff;}

/* ══════ CHARTS ══════ */
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:22px;}
.cbox{background:#fff;border-radius:18px;border:1px solid var(--border);padding:20px;box-shadow:0 4px 14px rgba(12,68,124,.06);}
.cbox h4{font-size:15px;font-weight:900;color:var(--navy);margin-bottom:14px;padding-bottom:10px;border-bottom:2px solid var(--bg);}
.cful{grid-column:1/-1;}

/* ══════ STICKY SAVE BAR ══════ */
.abar{background:#fff;border-top:2px solid var(--border);padding:14px;display:flex;justify-content:center;gap:10px;flex-wrap:wrap;box-shadow:0 -3px 14px rgba(12,68,124,.07);position:sticky;bottom:0;z-index:40;}

/* ══════ PRESENTATION ══════ */
.pov{display:none;position:fixed;inset:0;background:#051225;z-index:999;flex-direction:column;}
.pov.active{display:flex;}
.psl{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px;color:#fff;text-align:center;overflow:auto;}
.pnav{display:flex;align-items:center;justify-content:center;gap:16px;padding:16px;background:rgba(255,255,255,.06);border-top:1px solid rgba(255,255,255,.1);}
.pcnt{color:rgba(255,255,255,.6);font-size:14px;min-width:80px;text-align:center;}

::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-thumb{background:rgba(24,95,165,.25);border-radius:3px;}

@media(max-width:900px){
  .topnav{gap:2px;}.navbtn{padding:8px 10px;font-size:13px;}
  .navbtn .ico{font-size:16px;}
  .g2,.g3,.s4,.scards,.cgrid{grid-template-columns:1fr;}
  .cg3,.cg4{grid-template-columns:1fr 1fr;}
  .content{padding:14px;}
  .nav-sep{display:none;}
}
@media print{
  .site-header,.pagebar,.abar,.pov{display:none!important;}
  .content{max-width:100%;padding:0;}
  .pg{display:block!important;}
  .card{box-shadow:none;break-inside:avoid;border:1px solid #ccc;}
}

/* ══════ RATING SCALE LEGEND ══════ */
.scale-legend{
  display:flex;gap:4px;margin-bottom:16px;border-radius:14px;overflow:hidden;
  border:2px solid var(--border);background:#f5faff;
}
.scale-item{
  flex:1;padding:10px 4px;text-align:center;font-family:"Cairo",sans-serif;
  cursor:default;transition:transform .15s;
}
.scale-item:hover{transform:scaleY(1.05);z-index:1;}
.scale-item .snum{font-size:20px;font-weight:900;line-height:1;}
.scale-item .sdesc{font-size:11px;font-weight:700;margin-top:3px;line-height:1.2;}
.si1{background:#fdf0f0;border-left:1px solid #f0c0c0;}
.si1 .snum{color:#c0392b;}.si1 .sdesc{color:#a32d2d;}
.si2{background:#fef2e0;border-left:1px solid #f0d0a0;}
.si2 .snum{color:#b7620a;}.si2 .sdesc{color:#9a5008;}
.si3{background:#fefbe0;border-left:1px solid #e8d800;}
.si3 .snum{color:#8a7000;}.si3 .sdesc{color:#756000;}
.si4{background:#e6f1fb;border-left:1px solid #b5d4f4;}
.si4 .snum{color:var(--navy);}.si4 .sdesc{color:#0c3a6a;}
.si5{background:#e1f5ee;border-left:1px solid #9fdfd7;}
.si5 .snum{color:#085041;}.si5 .sdesc{color:#064535;}
.si6{background:#e0f0fe;border-left:1px solid #90c8f0;}
.si6 .snum{color:#014f82;}.si6 .sdesc{color:#013a62;}

/* Tooltip on hover */
.rgrp{position:relative;}
.rating-tip{
  display:none;position:absolute;top:-44px;left:50%;transform:translateX(-50%);
  background:var(--navy);color:#fff;padding:5px 12px;border-radius:8px;
  font-size:12px;font-weight:700;white-space:nowrap;z-index:100;
  box-shadow:0 4px 12px rgba(0,0,0,.2);
}
.rating-tip::after{content:"";position:absolute;top:100%;left:50%;transform:translateX(-50%);
  border:5px solid transparent;border-top-color:var(--navy);}


/* EMAIL PANEL */
.email-panel{background:linear-gradient(135deg,#e8f4fd,#e6f7f0);border:2px solid var(--blue);border-radius:16px;padding:20px;margin-bottom:18px;}
.email-title{font-size:16px;font-weight:900;color:var(--navy);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.email-formats{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;}
.efmt{padding:9px 18px;border-radius:10px;border:2px solid var(--border);background:#fff;font-family:"Cairo",sans-serif;font-size:14px;font-weight:700;color:var(--navy);cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:7px;}
.efmt:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.12);}
.efmt-gmail{border-color:#e24b4a;color:#c0392b;background:#fff5f5;}
.efmt-gmail:hover{background:#e24b4a;color:#fff;}
.efmt-pdf{border-color:var(--blue);color:var(--navy);background:#e8f4fd;}
.efmt-pdf:hover{background:var(--blue);color:#fff;}
.efmt-json{border-color:var(--green);color:#085041;background:#e6f7f2;}
.efmt-json:hover{background:var(--green);color:#fff;}
.efmt-csv{border-color:var(--gold);color:var(--gold);background:#fef9ec;}
.efmt-csv:hover{background:var(--gold);color:#fff;}
.email-note{font-size:12px;color:var(--muted);margin-top:10px;line-height:1.6;}


.brand-logo-img{display:block;margin:0 auto 10px;max-width:210px;width:clamp(135px,24vw,210px);height:auto;filter:drop-shadow(0 6px 18px rgba(0,0,0,.28));border-radius:4px;}
.hero .brand-logo-img{max-width:180px;margin-bottom:14px;filter:drop-shadow(0 6px 18px rgba(0,0,0,.24));background:rgba(255,255,255,.94);padding:8px 12px;border-radius:16px;}
.report-actions{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin:12px 0 4px;}
.report-note{font-size:13px;color:var(--muted);text-align:center;margin-bottom:12px;}
.analysis-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:14px 0;}
.analysis-box{background:#f8fbff;border:1px solid var(--border);border-radius:14px;padding:14px;}
.analysis-box h4{font-size:14px;color:var(--navy);margin-bottom:8px;}
.analysis-box ul{padding-right:18px;font-size:13px;line-height:1.9;}
@media(max-width:900px){.analysis-grid{grid-template-columns:1fr}.brand-logo-img{max-width:170px}}
</style>
</head>
<body>

<!-- ══════════ SITE HEADER WITH LOGO ══════════ -->
<header class="site-header">
  <div class="header-logo">
    <img class="brand-logo-img" src="data:image/png;base64," alt="شعار أكاديمية الفلاح">
    <div class="acname">أكاديمية الفلاح</div>
    <div class="acsub">نظام تقييم المكتبات ومراكز مصادر التعلم 2026</div>
  </div>
  <!-- TOP NAV -->
  <nav class="topnav">
    <button class="navbtn active" id="nav-home" onclick="pg('page-home','لوحة التحكم','nav-home')"><span class="ico">🏠</span> لوحة التحكم</button>
    <div class="nav-sep"></div>
