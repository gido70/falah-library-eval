              <div class="g2">
                <div class="fld"><label>نوع المكتبة الثانية</label><select id="f-et"><option>مكتبة الصفوف الصغيرة KG-4</option><option>مكتبة الصفوف الكبيرة 5-12</option><option>مكتبة رقمية</option><option>ركن قراءة</option><option>مكتبة متنقلة</option><option>أخرى</option></select></div>
                <div class="fld"><label>أخصائيها</label><input id="f-es" placeholder="الاسم أو اتركه فارغاً..."></div>
