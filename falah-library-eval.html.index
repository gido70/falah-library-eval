              <input id="f-stf" placeholder="العدد...">
            </div>
            <div class="fld full"><label>وصف مختصر للمكتبة (اختياري)</label><textarea id="f-ldesc" placeholder="الموقع، التقسيمات، ما يميزها..."></textarea></div>
          </div>
          <!-- EXTRA LIBRARY INLINE -->
          <div class="exbox" id="exbox">
            <div class="extog" onclick="togEx()">
              <div style="display:flex;align-items:center;gap:10px">
                <span style="font-size:20px">📚</span>
                <div>
                  <div>هل توجد مكتبة ثانية (إضافية) في المدرسة؟</div>
