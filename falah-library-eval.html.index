      <div id="eform" style="display:none">

<!-- RATING SCALE LEGEND - FIXED -->
<div class="card" style="margin-bottom:18px">
  <div class="cardh" style="margin-bottom:12px;padding-bottom:10px">
    <div class="cnum" style="font-size:16px">📏</div>
    <div><div class="ctitle">مقياس التقييم المعتمد</div><div class="csub">يُطبَّق على جميع محاور النموذج — احتفظ بهذا المقياس كمرجع أثناء التقييم</div></div>
  </div>
  <div class="scale-legend">
    <div class="scale-item si1"><div class="snum">1</div><div class="sdesc">غير موجود<br>ضعيف جداً</div></div>
    <div class="scale-item si2"><div class="snum">2</div><div class="sdesc">ضعيف<br>تدخل عاجل</div></div>
    <div class="scale-item si3"><div class="snum">3</div><div class="sdesc">مقبول<br>دون المستوى</div></div>
    <div class="scale-item si4"><div class="snum">4</div><div class="sdesc">جيد<br>الحد الأدنى</div></div>
    <div class="scale-item si5"><div class="snum">5</div><div class="sdesc">جيد جداً<br>فوق المستوى</div></div>
    <div class="scale-item si6"><div class="snum">6</div><div class="sdesc">متميز<br>نموذجي</div></div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:12px;font-size:13px">
    <div style="background:#fdf0f0;border-radius:10px;padding:10px 12px;border-right:3px solid #e24b4a">
      <strong style="color:#c0392b">1-2 ضعيف:</strong><br>
      <span style="color:#7a2020">المكتبة تحتاج تدخلاً عاجلاً وخطة تصحيحية فورية</span>
    </div>
    <div style="background:#fefbe0;border-radius:10px;padding:10px 12px;border-right:3px solid #c9a800">
      <strong style="color:#8a7000">3 مقبول:</strong><br>
      <span style="color:#5a4800">يوجد جهد لكنه دون المستوى المطلوب — يحتاج تحسيناً</span>
    </div>
    <div style="background:#e1f5ee;border-radius:10px;padding:10px 12px;border-right:3px solid #0f9d8a">
      <strong style="color:#085041">4-5-6 جيد→متميز:</strong><br>
      <span style="color:#054035">يلبي المعايير بشكل جيد ويمكن استخدامه نموذجاً للآخرين</span>
    </div>
  </div>
</div>


        <!-- S1 -->
        <div class="card">
          <div class="cardh"><div class="cnum">1</div><div><div class="ctitle">البيانات العامة</div><div class="csub">اسم المدرسة والمدينة والأخصائي — بدون رمز مكتبة</div></div></div>
          <div class="g2">
            <div class="fld"><label>المدينة / الإمارة</label><input id="f-city" readonly></div>
